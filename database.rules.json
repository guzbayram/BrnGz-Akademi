{
  "rules": {
    "drawings": {
      "$uid": {
        "meta": {
          ".read": true,
          ".write": "auth != null && auth.uid == $uid"
        },
        "strokes": {
          ".read": true,
          "$strokeId": {
            ".write": "auth != null && auth.uid == $uid"
          }
        }
      }
    },
    "savedDrawings": {
      "$uid": {
        ".read": true,
        "$fid": {
          "$strokeId": {
            ".write": "auth != null && auth.uid == $uid"
          }
        }
      }
    }
  }
}
